{
  "name": "CodeSandbox",
  "display_name": "代码安全沙箱",
  "version": "0.1.0",
  "project_type": "server",
  "description": "多语言代码安全执行沙箱 — 支持 Python/JavaScript/Go/Java/C++/Rust 的 Docker 隔离执行",
  "backend": {
    "language": "Python",
    "framework": "FastAPI",
    "runtime": "Python 3.12"
  },
  "ports": {
    "http": 8005
  },
  "dependencies": [
    "Docker Engine 24+",
    "docker-py",
    "fastapi>=0.115.0",
    "uvicorn[standard]>=0.32.0"
  ],
  "status": "development",
  "author": "DaoVirtrue",
  "tags": ["sandbox", "code-execution", "docker", "security", "multi-language"]
}
